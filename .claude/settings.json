{
  "$comment": "zuk-zuk プロジェクト共通の permission ルール。 試行 #2 ターミナルログ解析 (Bash 46 回中 67% が compound+redirect で毎回手動承認だった) を踏まえ、 安全な定型コマンドを allow に追加して自走度を上げる。 危険コマンドは deny で確実にブロック。",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(wc *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(which *)",
      "Bash(chmod +x *)",
      "Bash(cp * *)",
      "Bash(mv * *)",

      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git commit -q -m *)",
      "Bash(git commit --amend *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git push origin *)",
      "Bash(git stash *)",
      "Bash(git remote *)",
      "Bash(git config *)",

      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(node --version)",
      "Bash(node -e *)",
      "Bash(node -v)",
      "Bash(npx *)",

      "Bash(curl -s http://localhost:*)",
      "Bash(curl -sI http://localhost:*)",
      "Bash(curl -s -o /dev/null *)",
      "Bash(curl -s -o /tmp/* *)",
      "Bash(curl --max-time * http://localhost:*)",

      "Bash(lsof -i :*)",
      "Bash(lsof -ti :*)",
      "Bash(lsof -nP *)",

      "Bash(pkill -f *)",
      "Bash(kill *)",
      "Bash(sleep *)",

      "Bash(python3 -m http.server *)",
      "Bash(python3 -c *)",
      "Bash(tail -n * *)",
      "Bash(head -n * *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(curl -X DELETE *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fdx *)",
      "Bash(npm publish *)",
      "Bash(* > /etc/*)",
      "Bash(* >> /etc/*)",
      "Bash(* > /var/*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)"
    ]
  }
}
